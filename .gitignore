# Python cache/bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual envs
.venv/
venv/
env/

# Tool caches and coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/

# IDE/editor
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Build/dist
build/
dist/
*.egg-info/

# Local env vars
.env
.env.*

# Data artifacts (keep folder structure with .gitkeep)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
